#!/bin/sh
# pace-managed-hook
# Posts the FULL hook payload to the local pace daemon.
# v0.7: synchronous (waits for daemon ack), fail-loud (exit non-zero on failure).
PORT_FILE="${HOME}/.config/pace/port"
if [ ! -f "$PORT_FILE" ]; then
  echo "pace-hook: $PORT_FILE missing — daemon not running" >&2
  exit 1
fi
PORT=$(cat "$PORT_FILE" 2>/dev/null)
if [ -z "$PORT" ]; then
  echo "pace-hook: $PORT_FILE empty — daemon not initialized" >&2
  exit 1
fi

PAYLOAD=$(cat)
EVENT_ID=$(uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || echo "fallback-$$-$(date +%s)")
TS=$(python3 -c 'from datetime import datetime,timezone; print(datetime.now(timezone.utc).isoformat())' 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)
HOOK_TYPE="$1"

ENRICHED=$(printf '%s' "$PAYLOAD" | EVENT_ID="$EVENT_ID" TS="$TS" HOOK_TYPE="$HOOK_TYPE" python3 -c "
import json, sys, os
try:
    p = json.loads(sys.stdin.read() or '{}')
except Exception:
    p = {}

def stringify(x):
    if x is None:
        return ''
    if isinstance(x, str):
        return x
    return json.dumps(x)

tr = p.get('tool_response') or {}
if isinstance(tr, str):
    tr = {'text': tr}
exit_status = 'ok'
if isinstance(tr, dict) and (tr.get('error') or tr.get('is_error')):
    exit_status = 'error'
out = {
    'event_id': os.environ.get('EVENT_ID', ''),
    'timestamp': os.environ.get('TS', ''),
    'hook_type': os.environ.get('HOOK_TYPE', ''),
    'session_id': p.get('session_id', ''),
    'project_path': p.get('cwd', os.getcwd()),
    'tool_name': p.get('tool_name', ''),
    # v0.7: full payloads, no truncation. Brain sees everything.
    'tool_input': stringify(p.get('tool_input')),
    'tool_result': stringify(tr),
    'tool_exit_status': exit_status,
    'user_prompt': stringify(p.get('prompt')),
    'stop_reason': 'turn_complete' if p.get('stop_hook_active') else '',
}
print(json.dumps(out))
" 2>/dev/null)

if [ -z "$ENRICHED" ]; then
  echo "pace-hook: failed to build payload (python3 missing or stdin malformed)" >&2
  exit 1
fi

# Synchronous POST. 2s timeout. Fail-loud on error.
HTTP_CODE=$(curl -s -m 2 -o /dev/null -w '%{http_code}' \
  -X POST -H 'Content-Type: application/json' \
  --data "$ENRICHED" \
  "http://127.0.0.1:${PORT}/event")

case "$HTTP_CODE" in
  200)
    exit 0
    ;;
  000)
    echo "pace-hook: daemon unreachable on port ${PORT}" >&2
    exit 1
    ;;
  *)
    echo "pace-hook: daemon returned HTTP ${HTTP_CODE}" >&2
    exit 1
    ;;
esac
